---
layout: layouts/base
---
<article class="poem">
  <header class="poem-header">
    <h1 class="poem-title">{{ title }}</h1>
    <p class="poem-date">{{ display_date if display_date else date | formatDate }}</p>
    {% if tags and tags | length %}
    <ul class="poem-tags">
      {% for tag in tags %}
      <li class="poem-tag">{{ tag }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </header>

  <div class="poem-body">
    {{ content | safe }}
  </div>

  {% if commit_message or footnote %}
  <footer class="poem-footer">
    <hr class="poem-rule" />
    {% if commit_message %}
    <div class="poem-commit-message">{{ commit_message | markdownify | safe }}</div>
    {% endif %}
    {% if footnote %}
    <p class="poem-footnote">{{ footnote }}</p>
    {% endif %}
  </footer>
  {% endif %}

  <nav class="poem-nav">
    <a href="{{ '/' | url }}" class="poem-back">← All poems</a>
  </nav>
</article>
